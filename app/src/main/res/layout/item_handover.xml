<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp">

    <!-- Timeline marker keeps sequence readability in audit/history lists. -->
    <View
        android:id="@+id/timeline_dot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:background="@drawable/bg_status_verified"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/handover_card" />

    <View
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:background="@color/gray_100"
        app:layout_constraintBottom_toBottomOf="@id/handover_card"
        app:layout_constraintStart_toStartOf="@id/timeline_dot"
        app:layout_constraintTop_toBottomOf="@id/timeline_dot" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/handover_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="14dp"
        app:cardElevation="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/timeline_dot"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="@color/gray_100"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp">

            <!-- Visual status chip makes each handover event easier to scan. -->
            <TextView
                android:id="@+id/tv_handover_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_verified"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="HANDOVER"
                android:textColor="@color/status_green"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_handover_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@color/accent_blue"
                android:gravity="center"
                android:text="↔"
                android:textColor="@color/primary_blue"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/tv_handover_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_handover_title" />

            <TextView
                android:id="@+id/tv_handover_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Aman G. to Karan S."
                android:textColor="@color/gray_900"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/tv_handover_status"
                app:layout_constraintStart_toEndOf="@id/tv_handover_icon"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_handover_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="14 Oct 2023, 06:45 PM"
                android:textColor="@color/gray_500"
                android:textSize="11sp"
                app:layout_constraintStart_toStartOf="@id/tv_handover_title"
                app:layout_constraintTop_toBottomOf="@id/tv_handover_title" />

            <View
                android:id="@+id/divider_handover"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="@color/gray_100"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_handover_time" />

            <!-- Compact metadata panel fills space while improving scanability. -->
            <LinearLayout
                android:id="@+id/panel_handover_meta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@color/accent_blue"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider_handover">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Kit: A7 IV"
                    android:textColor="@color/gray_700"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Event: E-102"
                    android:textColor="@color/gray_700"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Gate B"
                    android:textColor="@color/gray_700"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Verified by Operations Desk"
                android:textColor="@color/gray_500"
                android:textSize="11sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/panel_handover_meta" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>